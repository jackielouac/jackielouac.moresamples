<script>

/* ================================= */
/* CHAT */
/* ================================= */

function sendMessage(){

const input = document.getElementById('chatInput');
const chatBox = document.getElementById('chatBox');

if(input.value.trim() === '') return;

const div = document.createElement('div');

div.className = 'glass rounded-2xl p-4';

div.innerHTML = `
<p class="text-blue-400 font-bold">You</p>
<p class="text-gray-300 mt-1">${input.value}</p>
`;

chatBox.appendChild(div);
chatBox.scrollTop = chatBox.scrollHeight;

input.value = '';

}

function openSubscription(){
alert('Premium Subscription Activated Demo\n\n₱1 per day\n\nFeatures:\n• Multiplayer Rooms\n• Exclusive Games\n• Premium Badge\n• Voice Chat');
}

function openChat(){
document.getElementById('chatInput').focus();
}

function scrollToGames(){
document.getElementById('games').scrollIntoView({behavior:'smooth'});
}

/* ================================= */
/* GAME ENGINE */
/* ================================= */

const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');

let currentGame = 'space';
let score = 0;
let highScore = localStorage.getItem('highscore') || 0;

document.getElementById('highScore').textContent = highScore;

/* ================================= */
/* SPACE DODGE */
/* ================================= */

let player = {
x:420,
y:430,
width:60,
height:60,
speed:8
};

let obstacles = [];

let keys = {};

window.addEventListener('keydown', e => {
keys[e.key] = true;
});

window.addEventListener('keyup', e => {
keys[e.key] = false;
});

function moveLeft(){
player.x -= 40;
}

function moveRight(){
player.x += 40;
}

function createObstacle(){
obstacles.push({
x:Math.random() * (canvas.width - 50),
y:-50,
size:50,
speed:4 + Math.random()*3
});
}

setInterval(() => {
if(currentGame === 'space'){
createObstacle();
}
},1000);

function updateSpaceGame(){

ctx.clearRect(0,0,canvas.width,canvas.height);

ctx.fillStyle = '#0f172a';
ctx.fillRect(0,0,canvas.width,canvas.height);

if(keys['ArrowLeft']) player.x -= player.speed;
if(keys['ArrowRight']) player.x += player.speed;

player.x = Math.max(0, Math.min(canvas.width-player.width, player.x));

ctx.fillStyle = '#3b82f6';
ctx.fillRect(player.x,player.y,player.width,player.height);

ctx.fillStyle = '#ef4444';

obstacles.forEach((o,index) => {

o.y += o.speed;

ctx.fillRect(o.x,o.y,o.size,o.size);

if(
player.x < o.x + o.size &&
player.x + player.width > o.x &&
player.y < o.y + o.size &&
player.y + player.height > o.y
){

alert('Game Over! Score: ' + score);

if(score > highScore){
localStorage.setItem('highscore',score);
document.getElementById('highScore').textContent = score;
}

score = 0;
obstacles = [];
}

if(o.y > canvas.height){
obstacles.splice(index,1);
score++;
document.getElementById('score').textContent = score;
}

});

requestAnimationFrame(updateSpaceGame);

}

/* ================================= */
/* SNAKE GAME */
/* ================================= */

let snake = [{x:10,y:10}];
let food = {x:15,y:15};
let dx = 1;
let dy = 0;

function drawSnake(){

ctx.fillStyle = '#0f172a';
ctx.fillRect(0,0,canvas.width,canvas.height);

ctx.fillStyle = '#22c55e';

snake.forEach(part => {
ctx.fillRect(part.x*20, part.y*20,18,18);
});

ctx.fillStyle = '#ef4444';
ctx.fillRect(food.x*20,food.y*20,18,18);

let head = {
x:snake[0].x + dx,
y:snake[0].y + dy
};

snake.unshift(head);

if(head.x === food.x && head.y === food.y){
food = {
x:Math.floor(Math.random()*30),
y:Math.floor(Math.random()*20)
};
score++;
document.getElementById('score').textContent = score;
}else{
snake.pop();
}

if(
head.x < 0 ||
head.y < 0 ||
head.x > 44 ||
head.y > 24
){
alert('Snake Game Over!');
score = 0;
snake = [{x:10,y:10}];
}

}

window.addEventListener('keydown', e => {
if(currentGame !== 'snake') return;

if(e.key === 'ArrowUp'){
dx = 0;
dy = -1;
}

if(e.key === 'ArrowDown'){
dx = 0;
dy = 1;
}

if(e.key === 'ArrowLeft'){
dx = -1;
dy = 0;
}

if(e.key === 'ArrowRight'){
dx = 1;
dy = 0;
}

});

let snakeLoop;

/* ================================= */
/* MEMORY GAME */
/* ================================= */

function launchMemory(){

currentGame = 'memory';

document.getElementById('gameTitle').innerHTML = '🧠 Memory Flip';

ctx.clearRect(0,0,canvas.width,canvas.height);

ctx.fillStyle = '#111827';
ctx.fillRect(0,0,canvas.width,canvas.height);

ctx.fillStyle = 'white';
ctx.font = 'bold 40px sans-serif';
ctx.fillText('Memory Game Demo',250,200);

ctx.font = '24px sans-serif';
ctx.fillText('Tap cards feature can be expanded.',250,260);

}

/* ================================= */
/* SWITCH GAME */
/* ================================= */

function launchGame(type){

currentGame = type;
score = 0;
document.getElementById('score').textContent = score;

if(type === 'space'){

document.getElementById('gameTitle').innerHTML = '🚀 Space Dodge';
updateSpaceGame();

}

if(type === 'snake'){

document.getElementById('gameTitle').innerHTML = '🐍 Neon Snake';

clearInterval(snakeLoop);

snakeLoop = setInterval(() => {
drawSnake();
},100);

}

}

launchGame('space');

</script>

</body>
